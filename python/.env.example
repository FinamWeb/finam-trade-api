# Copy to .env (gitignored) and fill in real values before running the examples.
#
#   cp .env.example .env
#   # edit .env
#   set -a && source .env && set +a
#   python examples/auth_and_account.py

# API secret issued by Finam (looks like: tapi_sk_XXXXXXXXXXXXXXXXXXXX).
# Treat as a password — never commit, never paste into chat/issues.
FINAM_SECRET=tapi_sk_replace_me

# A real Finam account number visible to FINAM_SECRET.
